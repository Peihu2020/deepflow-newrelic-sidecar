# New Relic 配置
NEW_RELIC_ACCOUNT_ID=4188218
NEW_RELIC_LICENSE_KEY=27c4aebef854e3081ea258b1d152ee8eFFFFNRAL

NEW_RELIC_DEBUG_MODE=false

# Sidecar Configuration
BATCH_SIZE=200
FLUSH_INTERVAL=3s
LOG_LEVEL=info
HTTP_PORT=8080
DEBUG_DIR=./debug
SAVE_DEBUG_DATA=false

# Log type filters (set to true to enable, false to disable)
ENABLE_L7=true
ENABLE_L4=true
ENABLE_METRICS=false

# HTTP mode configuration
DEEPFLOW_HTTP_ENDPOINT=/api/deepflow-data

# Performance tuning
MAX_QUEUE_SIZE=10000
WORKER_COUNT=4
RATE_LIMIT_PER_SEC=20000
RATE_LIMIT_BURST=50000
HTTP_READ_TIMEOUT=30s
HTTP_WRITE_TIMEOUT=30s