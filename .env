# New Relic 配置
NEW_RELIC_ACCOUNT_ID=******
NEW_RELIC_LICENSE_KEY=******

NEW_RELIC_DEBUG_MODE=false

# HTTP Server
HTTP_PORT=8080
DEEPFLOW_HTTP_ENDPOINT=/api/deepflow-data
SAVE_DEBUG_DATA=false

# Processing
BATCH_SIZE=100
FLUSH_INTERVAL=3s
WORKER_COUNT=4
MAX_QUEUE_SIZE=10000
RATE_LIMIT_PER_SEC=20000
RATE_LIMIT_BURST=50000

# Log Types
ENABLE_L7=true
ENABLE_L4=true
ENABLE_METRICS=false

# Kafka Producer
KAFKA_PRODUCER_ENABLED=true
KAFKA_BROKERS=10.8.152.29:9092
KAFKA_TOPIC=deepflow-logs
KAFKA_PRODUCER_TIMEOUT=5s

# Kafka Consumer
KAFKA_CONSUMER_ENABLED=true
KAFKA_CONSUMER_GROUP=deepflow-sidecar
KAFKA_CONSUMER_TOPICS=deepflow-logs
KAFKA_CONSUMER_OFFSET=newest