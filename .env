# New Relic 配置
NEW_RELIC_ACCOUNT_ID=4188218
NEW_RELIC_LICENSE_KEY=27c4aebef854e3081ea258b1d152ee8eFFFFNRAL

NEW_RELIC_DEBUG_MODE=false

# Sidecar Configuration
BATCH_SIZE=100
FLUSH_INTERVAL=5s
LOG_LEVEL=info
HTTP_PORT=8080
DEBUG_DIR=./debug
SAVE_DEBUG_DATA=true

# DeepFlow Data Source Mode
# Set to "http" to receive data via HTTP POST from deepflow-agent
# Set to "file" to read logs directly from deepflow-agent log files
DEEPFLOW_SOURCE_MODE=file

# File mode configuration (only used when DEEPFLOW_SOURCE_MODE=file)
DEEPFLOW_LOG_DIR=/var/log/deepflow-agent/
DEEPFLOW_POLL_INTERVAL=5s
DEEPFLOW_START_FROM_END=true

# HTTP mode configuration (only used when DEEPFLOW_SOURCE_MODE=http)
DEEPFLOW_HTTP_ENDPOINT=/api/deepflow-data